    {
      "id": "fSOM30Kc5ByvXzMxU_ZND",
      "type": "text",
      "x": 1016.6467827191493,
      "y": -94.39368057250948,
      "width": 461.9398713563735,
      "height": 330.298940381506,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
